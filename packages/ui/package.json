{
  "name": "agentvis-ui",
  "version": "0.0.1",
  "description": "Production-grade React component library for Agentvis",
  "type": "module",
  "main": "./dist/agentvis-ui.umd.js",
  "module": "./dist/agentvis-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/agentvis-ui.es.js",
      "require": "./dist/agentvis-ui.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@dagrejs/dagre": "^1.0.0",
    "@xyflow/react": "^12.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.8",
    "@mui/icons-material": "^7.3.8",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@dagrejs/dagre": "^1.1.8",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@xyflow/react": "^12.10.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "sideEffects": false,
  "keywords": [
    "react",
    "components",
    "agentvis",
    "ui"
  ],
  "license": "MIT",
  "dependencies": {}
}
